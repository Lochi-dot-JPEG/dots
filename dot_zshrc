# Lines configured by zsh-newuser-install
HISTFILE=~/.histfile
HISTSIZE=1000000
SAVEHIST=1000000
setopt autocd
unsetopt beep
zstyle :compinstall filename '/home/lochie/.zshrc'

autoload -Uz compinit
compinit
# End of lines added by compinstall

export MANPAGER="sh -c 'col -bx | bat -l man -p'"
export MANROFFOPT="-c"

alias tmpsound='cp -t $HOME/Documents/music/temp_soundbank/'
alias grep='grep --color=auto'
alias game='cd /home/lochie/Documents/Game/'
alias blahajfetch="fastfetch --logo blahaj"
PS1='[\u@\h \W]\$ '
alias vi="nvim"
alias chz="chezmoi"
alias lg="lazygit"
alias cha="chezmoi apply"
alias dr='dotnet run --no-restore'
alias dua="dua i"
alias l="eza -l"
alias aseprite-lines="~/LegacyProjects/bin/aseprite"

alias s="~/Scripts/tmux-session-dispensary.sh"
bright() (
    brightnessctl set "$@"%
)
# https://askubuntu.com/questions/1506717/how-do-i-tell-man-to-use-batcat-to-view-man-pages
xset r rate 200 30

# Created by `pipx` on 2024-11-03 06:02:38
export PATH="$PATH:/home/lochie/.local/bin"
export PATH="$PATH:/home/lochie/Scripts"
# Add go install apps to path https://wiki.archlinux.org/title/Go#Install_directory
export PATH="$PATH:$(go env GOBIN):$(go env GOPATH)/bin"
export PATH="$PATH:/home/lochie/.cargo/bin"
export PATH="$PATH:/home/lochie/.emacs.d/bin/"

# oh-my-zsh setup


ZSH_CACHE_DIR=$HOME/.cache/oh-my-zsh
if [[ ! -d $ZSH_CACHE_DIR ]]; then
  mkdir $ZSH_CACHE_DIR
fi

eval "$(starship init zsh)"
source /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
source /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh

alias ls='eza --color=auto --icons auto'

bindkey -e

